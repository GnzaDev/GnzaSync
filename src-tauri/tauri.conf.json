{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "GnzaSync",
  "version": "1.1.0",
  "identifier": "com.gnzasync.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "GnzaSync",
        "label": "main",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      },
      {
        "title": "Overlay",
        "label": "overlay",
        "width": 800,
        "height": 250,
        "resizable": true,
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "alwaysOnTop": true,
        "url": "/overlay"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "publisher": "Gnza",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../backend/main.py",
      "../backend/audio_capture.py",
      "../backend/whisper_service.py",
      "../backend/translator.py",
      "../backend/requirements.txt"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
